includes:
	- phpstan-baseline.neon

parameters:
	excludePaths:
		- test/EndToEnd/*/ExampleTest.php
		- test/Phar/*/ExampleTest.php

	inferPrivatePropertyTypeFromConstructor: true

	level: max

	paths:
		- src/
		- test/
		- .php-cs-fixer.php
		- rector.php

	tmpDir: .build/phpstan/

	treatPhpDocTypesAsCertain: false
